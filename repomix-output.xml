            response: error.response?.data,
            },
            { status: error.response?.status || 500 }
        );
        }

        logErrorResponse({ message: (error as Error).message });

        return NextResponse.json(
            { error: "Internal Server Error" },
            { status: 500 }
        );
    }
}
</file>

