.navLink::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width var(--transition-base);
}

.navLink:hover,
.navLink.active {
    color: var(--color-text-primary);
}

.navLink.active::after,
.navLink:hover::after {
