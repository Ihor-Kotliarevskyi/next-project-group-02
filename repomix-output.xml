.wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: #FFF2EC;
}

.content {
    width: 100%;
    padding: 0 20px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    flex: 1; 
}

@media (min-width: 375px) {
    .content {
        padding: 0 24px;
    }
}

.form {
    max-width: 335px;
    width: 100%;
    margin: 0 auto;
}

.header {
    height: 72px;
    display: flex;
    align-items: center;
    padding: 0 20px;
}

.buttonsBlock {
    display: flex;
    width: 100%;
    max-width: 335px;
    margin: 64px auto 32px;
}

.authBtn {
    width: 50%;
    text-align: center;
    padding: 12px 0 8px;
    cursor: pointer;
    position: relative;
    color: #8f8178;
    transition: 0.2s;
}

.authBtn:hover,
.authBtn.active {
    color: #000;
}

.title {
    text-align: center;
    margin-bottom: 32px;
}

.formGroup {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
}

.formGroup label {
    font-size: 14px;
    font-weight: 500;
}

.input {
    width: 100%;
    height: 40px;
    padding: 0 16px;
    border-radius: 8px;
    border: 1px solid transparent;
    background-color: #ffe5d9;
    font-size: 14px;
}

.input::placeholder {
    color: #9a8f88;
}

.input:hover {
    background-color: #fdd9c9;
}

.input:focus {
    outline: none;
    border-color: #c7642f;
    background-color: #fff;
