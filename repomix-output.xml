  const res = await fetch(`${API_URL}/auth/refresh`, {
    method: "POST",
    headers: {
      Cookie: req.headers.get("cookie") ?? "",
    },
    cache: "no-store",
  });

  const data = await res.text();

  const response = new NextResponse(data, {
    status: res.status,
    headers: {
      "Content-Type": res.headers.get("Content-Type") ?? "application/json",
    },
  });

